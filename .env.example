# Copy this file to .env for local development.

# Local Postgres from docker-compose.yml.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oakattest

# BetterAuth local URLs.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=local-dev-change-me-at-least-32-characters

# Email. Without RESEND_API_KEY the app logs emails to the dev console.
EMAIL_FROM="OakAttest <no-reply@example.com>"
# RESEND_API_KEY=

# Burl AI helper: optional Bedrock-backed assistant for local development.
# The AU inference profile keeps Bedrock inference in Australian AWS regions
# when the account has access to that profile.
OAK_AI_PROVIDER=bedrock
OAK_AI_BEDROCK_MODEL_ID=au.anthropic.claude-haiku-4-5-20251001-v1:0
AWS_REGION=ap-southeast-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Evidence storage: Cloudflare R2 (S3-compatible).
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=oakattest-evidence-dev
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_REGION=auto

# Optional AWS S3-compatible fallback names. Use these instead of R2_* when
# targeting AWS S3 or another S3-compatible provider.
# S3_REGION=ap-southeast-2
# S3_BUCKET=oakattest-evidence-dev
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_KMS_KEY_ID=
# Set this only when the deployment should use AWS IAM role/profile credentials
# instead of explicit access keys.
# S3_USE_DEFAULT_CREDENTIAL_CHAIN=false
